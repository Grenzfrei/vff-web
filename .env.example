# Google Sheets Sync
# Service Account JSON for Google Cloud (used by scripts/sync-sheets.ts)
# Required for: npm run sync
# Obtain from: Google Cloud Console → Service Accounts → Create key (JSON)
# Scopes needed: Google Sheets API, Google Drive API (read-only)
#
# For local development (optional):
# - If using gws CLI with existing Google auth, leave blank
# - If using Service Account, set to full JSON content
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudflare Pages (set in CF Dashboard, not locally)
# Node.js version for CF Pages build
NODE_VERSION=20
